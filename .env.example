# Supabase — copy this file to `.env.local` and fill in your project's values.
# Find both under Supabase dashboard → Project Settings → API.
# `.env.local` is git-ignored (matches `*.local`), so your keys stay out of the repo.
# The anon key is safe to ship in a client bundle; row-level security guards the data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
